贪心算法：看看当前该行是否满足，如果不满足，往下找满足的，然后进行交换。这样处理完一行就不用管啦。如果一直没找到，就要返回-1
res = 0
for i in range(n):
    k = -1
    for j in range(n):
        if pos[j] <= i:
            k = j
            res += j-i
            break
    if k != -1:
        for j in range(k, i, -1):
            pos[j], pos[j-1] = pos[j-1], pos[j]
    else:
        return -1
return res



C++完整版本：（时间打败100%）
class Solution {
public:
    int minSwaps(vector<vector<int>>& grid) {
        int n = grid.size();
        vector<int>pos(n, -1);
        for (int i=0;i<n;++i){
            for (int j=n-1;j>-1;--j){
                if(grid[i][j] == 1){
                    pos[i] = j;
                    break;
                }
            }
        }
        int ans = 0;
        for (int i=0;i<n;++i){
            int k = -1;
            for (int j=i; j<n; ++j){
                if (pos[j] <= i){
                    k = j;
                    ans += j - i;
                    break;
                }
            }
            if (k!=-1){
                for(int j=k; j>i;--j){
                    swap(pos[j], pos[j-1]);
                }
            }else{
                return -1;
            }
        }
        return ans;
    }
};
